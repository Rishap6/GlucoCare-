PORT=5000
DB_PATH=glucocare.db
JWT_SECRET=change-this-to-a-strong-random-secret-in-production

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-publishable-key>
DATABASE_URL=postgresql://postgres:<your-password>@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# Optional LLM fallback (used when local AI confidence is low)
LLM_FALLBACK_ENABLED=true
LLM_FALLBACK_THRESHOLD=0.74
LLM_TIMEOUT_MS=10000
AI_DEBUG_SOURCE=false

# Choose one provider: openai | gemini
LLM_PROVIDER=openai

# OpenAI settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini


# Gemini settings
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Optional object storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=
S3_PUBLIC_BASE_URL=
S3_ACL=
S3_SIGNED_URL_TTL_SECONDS=900
S3_ENDPOINT=
