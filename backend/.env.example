PORT=5000
DB_PATH=glucocare.db
JWT_SECRET=change-this-to-a-strong-random-secret-in-production

# Optional LLM fallback (used when local AI confidence is low)
LLM_FALLBACK_ENABLED=true
LLM_FALLBACK_THRESHOLD=0.74
LLM_TIMEOUT_MS=10000
AI_DEBUG_SOURCE=false

# Choose one provider: openai | gemini
LLM_PROVIDER=openai

# OpenAI settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini


# Gemini settings
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
